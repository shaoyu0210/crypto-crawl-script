# ----- 推播 -----
# Discord webhook URL (建一個私人頻道 → 編輯頻道 → 整合 → Webhook → 新增)
DISCORD_WEBHOOK_URL=

# ----- 資料來源金鑰（皆可選，預設不啟用） -----

# CoinGecko Pro 金鑰（免費版可不填）
COINGECKO_API_KEY=

# CryptoPanic API token（若要啟用 CryptoPanic 新聞聚合）
CRYPTOPANIC_API_TOKEN=

# X (Twitter) API Bearer Token (Basic tier $200/mo)
# 預設 news_sources.yaml 中 twitter.enabled = false
X_API_BEARER_TOKEN=

# ----- 必要 -----
# 手機登入 PIN 碼（4 位以上數字）
PIN=
# token 簽名金鑰（隨機 32+ 字元，可用 `openssl rand -hex 32` 產生）
APP_SECRET=
# Cloud Scheduler 觸發 /tasks/refresh 的保護密鑰（隨機字串）
REFRESH_SECRET=

# ----- 警報推送（建議設定） -----
# Discord webhook（私人頻道 → 編輯頻道 → 整合 → Webhook → 新增）
# 手機裝 Discord 即收到原生推播：setup 觸發 / verified edge / 川普發文 / 事件提醒
DISCORD_WEBHOOK_URL=

# ----- 部署目標（選用） -----
# GCP 專案 ID；不填則用 `gcloud config set project` 的當前專案
GCP_PROJECT=
# 部署區域；預設 asia-east1（台灣，避開 Binance 對美國 IP 的封鎖）
GCP_REGION=asia-east1

# ----- 選用 -----
# 監控幣安 24h 量前 N 熱門永續標的（外加核心 5 幣），預設 10
TOP_N=10
# 本機開發模式：1 = snapshot 存本機檔不用 GCS（deploy.sh 會自動設為 0）
LOCAL_MODE=1
